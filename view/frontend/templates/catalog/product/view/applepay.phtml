/** @var string $block */

if ($block->canShowButton('Product') && !$block->isIdinVerificationRequired()): ?>
    <div id="apple-pay-catalog-product-view-component" data-bind="scope:'buckarooApplepayProduct'">
        <!-- ko template: getTemplate() --><!-- /ko -->

        <script>
            // Set up window.checkoutConfig before component loads (required for Magento core modules)
            (function() {
                var config = <?= /* @noEscape */ ($block->getApplepayConfig()); ?>;

                if (typeof window.checkoutConfig === 'undefined') {
                    window.checkoutConfig = config;
                    window.isCustomerLoggedIn = config.isCustomerLoggedIn || false;

                    if (typeof window.checkoutConfig.totalsData === 'undefined') {
                        window.checkoutConfig.totalsData = {};
                    }
                } else {
                    // Merge Apple Pay config
                    if (!window.checkoutConfig.payment) window.checkoutConfig.payment = {};
                    if (!window.checkoutConfig.payment.buckaroo) window.checkoutConfig.payment.buckaroo = {};

                    window.checkoutConfig.payment.buckaroo.buckaroo_magento2_applepay =
                        config.payment.buckaroo.buckaroo_magento2_applepay;
                }
            })();
        </script>

        <script type="text/x-magento-init">
            {
                "#apple-pay-catalog-product-view-component": {
                    "Magento_Ui/js/core/app": {
                        "components": {
                            "buckarooApplepayProduct": {
                                "component": "buckaroo/applepay/catalog-product-view",
                                "template": "Buckaroo_Magento2/catalog/product/view/applepay"
                            }
                        }
                    }
                }
            }
        </script>
    </div>
<?php endif; ?>
